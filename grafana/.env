# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=password

# OIDC via Authentik (generic OAuth2)
GF_AUTH_GENERIC_OAUTH_ENABLED=true
GF_AUTH_GENERIC_OAUTH_NAME=Authentik
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana-client-id
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=grafana-client-secret
GF_AUTH_GENERIC_OAUTH_SCOPES=openid profile email
GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://authentik.gasket-dev.local/application/o/authorize/
GF_AUTH_GENERIC_OAUTH_TOKEN_URL=https://authentik.gasket-dev.local/application/o/token/
GF_AUTH_GENERIC_OAUTH_API_URL=https://authentik.gasket-dev.local/application/o/userinfo/
GF_AUTH_GENERIC_OAUTH_TLS_SKIP_VERIFY_INSECURE=true
GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH=contains(groups[*], 'grafana-admins') && 'Admin' || 'Viewer'

# Disable sign-up / anonymous access
GF_USERS_ALLOW_SIGN_UP=false
GF_AUTH_DISABLE_LOGIN_FORM=false

# Server settings
GF_SERVER_DOMAIN=grafana.gasket-dev.local
GF_SERVER_ROOT_URL=https://grafana.gasket-dev.local
